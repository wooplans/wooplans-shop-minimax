# Cloudflare Pages Headers
# https://developers.cloudflare.com/pages/platform/headers/

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  X-XSS-Protection: 1; mode=block
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://connect.facebook.net https://www.clarity.ms https://scripts.clarity.ms; style-src 'self' 'unsafe-inline'; img-src 'self' https://wooplans.b-cdn.net https://www.facebook.com data:; font-src 'self'; connect-src 'self' https://wooplans.b-cdn.net https://wooplans-checkout.wooplans237.workers.dev https://api.chariow.com https://ipapi.co https://graph.facebook.com https://connect.facebook.net https://*.clarity.ms; frame-src https://www.facebook.com

# Static assets - aggressive caching (1 year)
/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Images - long cache with revalidation
/images/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# HTML pages - short cache, always revalidate
/plans/*
  X-Robots-Tag: index, follow
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/# plans index and category
/plans
  X-Robots-Tag: index, follow
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Homepage - moderate caching
/index.html
  Cache-Control: public, max-age=1800, stale-while-revalidate=7200

# Sitemap and robots
/sitemap.xml
  Content-Type: application/xml
  Cache-Control: public, max-age=86400

/robots.txt
  Cache-Control: public, max-age=86400

# Admin and analytics - no index
/admin.html
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-cache

/analytics.html
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-cache
